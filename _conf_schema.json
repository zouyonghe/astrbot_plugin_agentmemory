{
  "base_url": {
    "description": "agentmemory 服务地址",
    "type": "string",
    "default": "http://localhost:3111",
    "hint": "先运行 `npx @agentmemory/agentmemory` 启动 agentmemory 服务。"
  },
  "secret": {
    "description": "访问密钥",
    "type": "string",
    "default": "",
    "hint": "仅当 agentmemory 配置了 AGENTMEMORY_SECRET 时需要填写。"
  },
  "project": {
    "description": "项目名称",
    "type": "string",
    "default": "astrbot",
    "hint": "写入 agentmemory 时使用的项目名，用于区分不同机器人或部署环境。"
  },
  "timeout_seconds": {
    "description": "请求超时时间（秒）",
    "type": "float",
    "default": 3.0
  },
  "recall": {
    "description": "记忆召回",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用记忆召回",
        "type": "bool",
        "default": true,
        "hint": "开启后，会在请求大模型前从 agentmemory 搜索相关长期记忆并注入上下文。"
      },
      "limit": {
        "description": "召回数量上限",
        "type": "int",
        "default": 5,
        "hint": "每次最多注入多少条相关记忆。建议不要过大，避免 prompt 过长。"
      }
    }
  },
  "capture": {
    "description": "对话沉淀",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用对话沉淀",
        "type": "bool",
        "default": true,
        "hint": "开启后，会在机器人回复后把本轮纯文本对话片段写入 agentmemory。"
      },
      "max_user_chars": {
        "description": "用户消息最大长度",
        "type": "int",
        "default": 1000
      },
      "max_assistant_chars": {
        "description": "机器人回复最大长度",
        "type": "int",
        "default": 4000
      },
      "skip_keywords": {
        "description": "跳过沉淀关键词",
        "type": "list",
        "items": {
          "type": "string"
        },
        "default": [
          "看看记忆",
          "查看记忆",
          "记忆里有什么",
          "我是谁",
          "你记得什么"
        ],
        "hint": "用户消息包含这些关键词时，不把本轮回复自动写入 agentmemory，避免把记忆查询和不确定回答反复沉淀。"
      }
    }
  }
}
