{
  "base_url": {
    "description": "agentmemory 服务地址",
    "type": "string",
    "default": "http://localhost:3111",
    "hint": "先运行 `npx @agentmemory/agentmemory` 启动 agentmemory 服务。"
  },
  "secret": {
    "description": "访问密钥",
    "type": "string",
    "default": "",
    "hint": "仅当 agentmemory 配置了 AGENTMEMORY_SECRET 时需要填写。"
  },
  "project": {
    "description": "项目名称",
    "type": "string",
    "default": "astrbot",
    "hint": "用于区分不同机器人或部署环境，会参与记忆 session 作用域。"
  },
  "timeout_seconds": {
    "description": "请求超时时间（秒）",
    "type": "float",
    "default": 3.0
  },
  "admin_only": {
    "description": "仅管理员可使用记忆",
    "type": "bool",
    "default": false,
    "hint": "开启后，只有 AstrBot 判定为 admin 的用户会触发记忆沉淀、命令和 LLM 工具。"
  },
  "recall": {
    "description": "记忆召回",
    "type": "object",
    "items": {
      "limit": {
        "description": "召回数量上限",
        "type": "int",
        "default": 5,
        "hint": "命令或 LLM 工具每次最多返回多少条相关记忆。"
      },
      "overfetch_factor": {
        "description": "召回过滤前的过量检索倍数",
        "type": "int",
        "default": 10,
        "hint": "为了按会话过滤结果，会先请求 limit 的多少倍候选记忆。"
      },
      "overfetch_max_results": {
        "description": "召回过滤前的最大检索数量",
        "type": "int",
        "default": 50,
        "hint": "限制每次向 agentmemory 请求的候选记忆总数。"
      }
    }
  },
  "capture": {
    "description": "对话沉淀",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用对话沉淀",
        "type": "bool",
        "default": true,
        "hint": "开启后，会在机器人回复后把本轮纯文本对话片段写入 agentmemory。"
      },
      "max_user_chars": {
        "description": "用户消息最大长度",
        "type": "int",
        "default": 1000
      },
      "max_assistant_chars": {
        "description": "机器人回复最大长度",
        "type": "int",
        "default": 4000
      }
    }
  }
}
